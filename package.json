{
  "name": "lgym-app-mobile",
  "version": "4.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start --clear",
    "android": "npx expo start --android",
    "ios": "expo run:ios",
    "web": "npx expo start --web --port 8083",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "typecheck": "tsc --noEmit",
    "build:android": "eas build -p android --profile preview",
    "build:androidDev": "eas build -p android --profile preview2",
    "build:ios": "eas build -p ios --profile preview",
    "submit:ios": "eas submit -p ios --latest",
    "clean-setup": "rimraf ./enums && rimraf ./interfaces",
    "generate:api": "orval"
  },
  "dependencies": {
    "@expo-google-fonts/caveat": "0.4.2",
    "@expo-google-fonts/nunito": "0.4.2",
    "@expo-google-fonts/open-sans": "0.4.2",
    "@expo-google-fonts/teko": "0.4.1",
    "@expo/metro-runtime": "6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/native": "7.1.11",
    "@react-navigation/native-stack": "7.3.16",
    "@shopify/react-native-skia": "2.2.12",
    "@tanstack/react-query": "5.90.20",
    "axios": "1.9.0",
    "crypto-js": "4.2.0",
    "expo": "54.0.0",
    "expo-application": "7.0.7",
    "expo-clipboard": "8.0.8",
    "expo-constants": "18.0.9",
    "expo-crypto": "~15.0.9",
    "expo-font": "14.0.8",
    "expo-linear-gradient": "15.0.7",
    "expo-linking": "~8.0.12",
    "expo-localization": "17.0.8",
    "expo-location": "19.0.7",
    "expo-router": "6.0.7",
    "expo-secure-store": "14.0.0",
    "expo-splash-screen": "31.0.10",
    "expo-status-bar": "3.0.8",
    "expo-updates": "29.0.11",
    "i18next": "25.8.10",
    "install": "0.13.0",
    "intl-pluralrules": "2.0.1",
    "nativewind": "2.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "16.5.4",
    "react-native": "0.81.4",
    "react-native-calendar-strip": "2.2.6",
    "react-native-gesture-handler": "2.28.0",
    "react-native-keyboard-aware-scroll-view": "0.9.5",
    "react-native-reanimated": "4.1.1",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "1.5.0",
    "react-native-toast-message": "2.3.3",
    "react-native-vector-icons": "10.0.2",
    "react-native-web": "0.21.0",
    "react-native-worklets": "0.5.1",
    "uniqid": "5.4.0",
    "victory-native": "41.16.1",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@react-native/metro-babel-transformer": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.6",
    "@types/react-native-vector-icons": "^6.4.17",
    "@types/uniqid": "^5.3.4",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-plugin-dotenv": "^0.1.1",
    "dotenv": "^17.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "orval": "^8.2.0",
    "prettier": "^3.8.3",
    "react-native-dotenv": "^3.4.9",
    "react-test-renderer": "19.1.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "3.3.2",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "private": true
}
