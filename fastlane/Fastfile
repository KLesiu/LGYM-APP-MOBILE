require "base64"

default_platform(:ios)

def required_env!(name)
  value = ENV[name].to_s.strip
  UI.user_error!("Missing required environment variable #{name}") if value.empty?
  value
end

def exact_ios_build!(app_identifier:, app_version:, build_number:)
  app = Spaceship::ConnectAPI::App.find(app_identifier)
  UI.user_error!("Unable to find App Store Connect app #{app_identifier}") unless app

  builds = Spaceship::ConnectAPI::Build.all(
    app_id: app.id,
    version: app_version,
    build_number: build_number,
    platform: "IOS"
  )

  matches = builds.select do |build|
    build.app_version == app_version && build.version == build_number
  end

  UI.user_error!(
    "Expected exactly one iOS build for version #{app_version} build #{build_number}, found #{matches.length}"
  ) unless matches.length == 1

  matches.first
end

platform :ios do
  desc "Submit an existing iOS build for App Review using metadata only"
  lane :submit_review do
    asc_key_id = required_env!("ASC_KEY_ID")
    asc_issuer_id = required_env!("ASC_ISSUER_ID")
    asc_key_p8_base64 = required_env!("ASC_KEY_P8_BASE64")
    app_version = required_env!("APP_VERSION")
    ios_build_number = required_env!("IOS_BUILD_NUMBER")

    api_key = app_store_connect_api_key(
      key_id: asc_key_id,
      issuer_id: asc_issuer_id,
      key_content: Base64.decode64(asc_key_p8_base64),
      is_key_content_base64: false
    )

    exact_ios_build!(
      app_identifier: "com.lesiuuu.lgymappmobile",
      app_version: app_version,
      build_number: ios_build_number
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.lesiuuu.lgymappmobile",
      metadata_path: File.expand_path("metadata", __dir__),
      app_version: app_version,
      build_number: ios_build_number,
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true
    )
  end
end
